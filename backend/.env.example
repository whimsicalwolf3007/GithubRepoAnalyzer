# Database
DATABASE_URL=postgresql+asyncpg://autodev:autodev@localhost:5432/autodev_db

# GitHub Personal Access Token
GITHUB_TOKEN=ghp_your_token_here

# AI Provider: "openrouter" or "gemini"
AI_PROVIDER=openrouter

# OpenRouter Configuration (get your free key at https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your_key_here
OPENROUTER_MODEL=deepseek/deepseek-v4-flash:free

# Google Gemini API Key (optional fallback, only needed when AI_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Docker Build Settings
DOCKER_TIMEOUT=300
MAX_CONCURRENT_BUILDS=3

# Server
HOST=0.0.0.0
PORT=8000
